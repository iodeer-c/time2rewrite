# Copy this file to config/llm.yaml and fill in real values locally.
default_role: parser
roles:
  parser:
    model_type: openai
    model_name: qwen3-max
    api_base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    api_key_env: PARSER_API_KEY
    api_key: ""
    proxy_url_env: PARSER_PROXY_URL
    proxy_url: ""
    verify_ssl: false
    additional_params:
      temperature: 0
      stream_usage: true
      extra_body:
        enable_thinking: false
  rewriter:
    model_type: openai
    model_name: qwen-plus
    api_base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    api_key_env: REWRITER_API_KEY
    api_key: ""
    proxy_url_env: REWRITER_PROXY_URL
    proxy_url: ""
    verify_ssl: false
    additional_params:
      temperature: 0
      stream_usage: true
      extra_body:
        enable_thinking: false
